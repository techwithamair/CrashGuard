import ctypes
import os
import sys
import time
import subprocess
import pyttsx3
import speech_recognition as sr

try:
    _F = ctypes.CFUNCTYPE(None, ctypes.c_char_p, ctypes.c_int, ctypes.c_char_p, ctypes.c_int, ctypes.c_char_p)
    def _silent(*a): pass
    ctypes.cdll.LoadLibrary('libasound.so.2').snd_lib_error_set_handler(_F(_silent))
except:
    pass

class _HideStderr:
    def __enter__(self):
        try:
            self._null = open(os.devnull, 'w')
            self._old  = os.dup(2)
            sys.stderr.flush()
            os.dup2(self._null.fileno(), 2)
        except:
            pass
        return self
    def __exit__(self, *a):
        try:
            sys.stderr.flush()
            os.dup2(self._old, 2)
            os.close(self._old)
            self._null.close()
        except:
            pass

_tts = None
try:
    _tts = pyttsx3.init()
    _tts.setProperty('rate', 145)
    _tts.setProperty('volume', 1.0)
    print("[TTS] pyttsx3 ready")
except Exception as e:
    print(f"[TTS] failed: {e}")

def speak(text):
    print(f"[SPEAK] {text}")
    if _tts:
        try:
            _tts.say(text)
            _tts.runAndWait()
            return
        except Exception as e:
            print(f"[SPEAK] pyttsx3 error: {e}")
    try:
        subprocess.run(['espeak', '-v', 'en', '-s', '145', '-a', '200', text], timeout=20, capture_output=True)
    except Exception as e:
        print(f"[SPEAK] espeak error: {e}")

_YES = [
    "yes", "yeah", "yep", "yup", "yea", "ya",
    "okay", "ok", "fine", "good", "great",
    "alright", "all right", "sure", "correct",
    "safe", "cancel", "stop", "im fine",
    "i am fine", "i am okay", "i'm fine",
    "i'm okay", "am fine", "am okay",
]

_NO = [
    "no", "nope", "nah", "negative",
    "help", "hurt", "pain", "injured",
    "emergency", "accident", "need help",
    "i need", "danger", "not okay",
    "not fine", "sos", "mayday",
    "ambulance", "hospital", "doctor",
]

def _classify(text):
    if not text:
        return None
    text = text.lower().strip()
    print(f"[CLASS] Checking: '{text}'")
    for w in _YES:
        if w in text:
            print(f"[CLASS] YES: '{w}'")
            return "OKAY"
    for w in _NO:
        if w in text:
            print(f"[CLASS] NO: '{w}'")
            return "HELP"
    return None

_rec = sr.Recognizer()
_rec.energy_threshold         = 100
_rec.dynamic_energy_threshold = True
_rec.pause_threshold          = 1.0

def _listen_google(timeout=15):
    try:
        with _HideStderr():
            mic = sr.Microphone()
        with mic as source:
            print("[MIC] Calibrating...")
            _rec.adjust_for_ambient_noise(source, duration=1)
            print(f"[MIC] Listening {timeout}s — SPEAK NOW")
            audio = _rec.listen(source, timeout=timeout, phrase_time_limit=8)
        print("[GOOGLE] Sending to Google...")
        text = _rec.recognize_google(audio)
        text = text.lower().strip()
        print(f"[GOOGLE] Heard: '{text}'")
        return text
    except sr.WaitTimeoutError:
        print("[GOOGLE] Timeout")
        return "timeout"
    except sr.UnknownValueError:
        print("[GOOGLE] Could not understand")
        return "unknown"
    except sr.RequestError as e:
        print(f"[GOOGLE] No internet: {e}")
        return "no_wifi"
    except Exception as e:
        print(f"[GOOGLE] Error: {e}")
        return "error"

def _listen_once(timeout=15):
    text = _listen_google(timeout)
    if text not in ("timeout", "unknown", "no_wifi", "error", ""):
        match = _classify(text)
        if match:
            return match
        return "no_match"
    return text

def ask_and_listen():
    speak("Accident detected! Are you okay? Say YES if you are fine. Say NO if you need help. You have 15 seconds.")
    print("\n[ASR] Attempt 1 of 2")
    result1 = _listen_once(timeout=15)
    if result1 in ("OKAY", "HELP"):
        return result1
    if result1 == "timeout":
        speak("I did not hear you. Say YES if okay or NO if you need help.")
    elif result1 == "no_match":
        speak("I heard you but was not clear. Please say YES or NO.")
    else:
        speak("Please say YES or NO.")
    print("\n[ASR] Attempt 2 of 2")
    result2 = _listen_once(timeout=15)
    if result2 in ("OKAY", "HELP"):
        return result2
    print("\n[ASR] No response after 2 attempts")
    speak("No response detected. Sending emergency alert now.")
    return "TIMEOUT"

def ask_driver():
    return ask_and_listen()
